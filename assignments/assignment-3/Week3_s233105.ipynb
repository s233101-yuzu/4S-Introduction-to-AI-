    "T = np.array([[ 1, -2,  1],\n",
    "              [ 3,  1, -1]])\n",
    "rank = np.linalg.matrix_rank(T)\n",
    "n_rows, n_cols = T.shape\n",
    "is_onto = (rank == n_rows)       # rank == m (output dimension)\n",
    "is_one_to_one = (rank == n_cols) # rank == n (input dimension)\n",
